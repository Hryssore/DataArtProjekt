COMPOSE_PROJECT_NAME=classic-web-chat

POSTGRES_DB=chat_app
POSTGRES_USER=chat
POSTGRES_PASSWORD=chat
POSTGRES_PORT=5432

BACKEND_NODE_ENV=development
BACKEND_PORT=3000
FRONTEND_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
RESET_PASSWORD_URL_BASE=http://localhost:5173/reset-password

SESSION_COOKIE_NAME=chat_sid
SESSION_TTL_DAYS=30
RESET_TOKEN_TTL_MINUTES=30
UPLOADS_DIR=src/storage/uploads
MAILBOX_DIR=src/storage/mailbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_google_app_password
MAIL_FROM=your_email@gmail.com
MAILPIT_UI_PORT=8025
MAX_TEXT_BYTES=3072
MAX_FILE_SIZE_BYTES=20971520
MAX_IMAGE_SIZE_BYTES=3145728
TRANSLATION_API_URL=http://translator:5000/translate
TRANSLATION_API_KEY=
TRANSLATION_TIMEOUT_MS=15000
TRANSLATION_LOAD_ONLY=uk,en,pl,de,es,fr,it,pt,tr,ru

VITE_API_URL=http://localhost:3000/api
VITE_SOCKET_URL=http://localhost:3000
VITE_DEV_MAILBOX_URL=http://localhost:8025
