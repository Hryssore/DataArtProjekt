NODE_ENV=development
APP_PORT=3000
FRONTEND_ORIGIN=http://localhost:5173
DATABASE_URL=postgres://chat:chat@postgres:5432/chat_app
SESSION_COOKIE_NAME=chat_sid
SESSION_TTL_DAYS=30
RESET_TOKEN_TTL_MINUTES=30
UPLOADS_DIR=src/storage/uploads
